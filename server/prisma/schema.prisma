datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

model User {
  id String @id @default(uuid(4))

  email       String @unique
  employee_Id Int    @unique
  password    String
  publicKey          String?
  encryptedPrivateKey String?
  cryptoSalt          String?

  isTemporaryPassword Boolean  @default(false) // нужно ли менять пароль


  name    String
  surname String

  role             Role

  sessions Session[]
  chatMembers      ChatMember[]
  messages         Message[]
  createdPolls Poll[]
  pollVotes    PollVote[]

  @@map("users")
}

model Session {
  id           String   @id @default(uuid(4))
  refreshToken String   @unique
  userAgent    String?  // браузер/устройство
  ip           String?  // IP адрес
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Chat {
  id          String   @id @default(uuid(4))
  type        ChatType
  name        String?
  description String?
  createdAt   DateTime @default(now())

  members  ChatMember[]
  messages Message[]


  @@map("chats")
}

model ChatMember {
  id       String         @id @default(uuid(4))
  role     ChatMemberRole @default(member)
  joinedAt DateTime       @default(now())

  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@map("chat_members")
}

model Message {
  id                    String   @id @default(uuid(4))
  encryptedText         String
  encryptedKeyRecipient String?
  encryptedKeySender    String?
  senderPublicKey       String?  // ← публичный ECDH ключ отправителя
  groupKeys             MessageGroupKey[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  isRead                Boolean  @default(false)

  chatId   String
  chat     Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId String
  sender   User   @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model MessageGroupKey {
  id           String @id @default(uuid(4))
  userId       String
  encryptedKey String // AES ключ зашифрованный RSA ключом этого юзера

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@map("message_group_keys")
}

model Poll {
  id          String     @id @default(uuid(4))
  title       String
  description String?
  type        PollType
  isAnonymous Boolean    @default(false)
  startsAt    DateTime   @default(now())
  endsAt      DateTime
  createdAt   DateTime   @default(now())

  creatorId   String
  creator     User       @relation(fields: [creatorId], references: [id])

  options     PollOption[]
  votes       PollVote[]

  @@map("polls")
}

model PollOption {
  id     String @id @default(uuid(4))
  text   String
  order  Int

  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)

  votes  PollVote[]

  @@map("poll_options")
}

model PollVote {
  id        String   @id @default(uuid(4))
  createdAt DateTime @default(now())

  pollId    String
  poll      Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)

  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  userId    String
  user      User   @relation(fields: [userId], references: [id])

  @@unique([pollId, userId, optionId])
  @@map("poll_votes")
}

enum PollType {
  single   // одиночный выбор
  multiple // множественный выбор
}

enum Role {
  admin
  user
}

enum ChatType {
  direct
  group
  channel
}

enum ChatMemberRole {
  owner
  admin
  member
}

